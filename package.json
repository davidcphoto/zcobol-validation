{
  "name": "zcobol-validation",
  "displayName": "zCobol Validation",
  "description": "Cobol validations",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:cobol",
    "onLanguage:COBOL",
    "workspaceContains:**/*.cbl",
    "workspaceContains:**/*.cob",
    "workspaceContains:**/*.cobol",
    "workspaceContains:**/*.cpy"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [],
    "configuration": {
      "title": "zCobol Validation",
      "properties": {
        "zcobol-validation.enableUnusedVariableCheck": {
          "type": "boolean",
          "default": true,
          "description": "Ativar validação de variáveis não utilizadas"
        }
      }
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/mocha": "^10.0.2",
    "@types/node": "18.x",
    "eslint": "^8.50.0",
    "glob": "^10.3.3",
    "mocha": "^10.2.0",
    "typescript": "^5.2.2",
    "@vscode/test-electron": "^2.3.4"
  }
}
